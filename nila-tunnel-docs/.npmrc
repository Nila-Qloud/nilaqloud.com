# Lock to exact versions — no semver range resolution surprises.
save-exact=true

# Use package-lock.json for deterministic installs.
package-lock=true

# Security: sharp requires native bindings via install scripts, so we
# can't globally disable scripts. Instead we verify integrity via:
# 1. npm ci — validates SHA-512 hashes from package-lock.json
# 2. npm audit — checks for known vulnerabilities
# 3. CI dependency allowlist — rejects unexpected new packages
